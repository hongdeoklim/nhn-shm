{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.shm.nhnetworks.co.kr/api/$1"
    },
    {
      "source": "/storage/(.*)",
      "destination": "https://api.shm.nhnetworks.co.kr/storage/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
